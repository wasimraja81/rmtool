c   16)   SUBROUTINE: mdian(V,N,x)

c         Author: Wasim Raja
c         Date: 01-05-2010
c         
c         This subroutine calculates the median "x" of a 
c         vector "V" given its length "N". 

          subroutine median(V,N,x)
          real*4 V(*), x, S(65536)
          integer*4 N
          integer*4 i
          real*4 accum

          do i = 1,N
             S(i) = V(i)
          enddo

          call sort_ascending(V,N,S)
          x = S(int(N/2)+1)
          end

