        real*8 A(*)
        real*8 RMS,AMEAN, AN, DIFF, AMEAN0, RMS0  
        integer*4 NP, I, ITER  
C
        ITER=0
C
101     ITER=ITER+1
        AMEAN=0.0
        AN=0.0
C
