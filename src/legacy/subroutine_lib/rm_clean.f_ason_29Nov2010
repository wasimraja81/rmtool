         IF(ITER.EQ.1)GO TO 1
         DIFF=ABS(A(I)-AMEAN0)
         IF(DIFF.LE.(4.*RMS))GO TO 1
         GO TO 2
1        AMEAN=A(I)+AMEAN
         AN=AN+1.
2        CONTINUE
        END DO
