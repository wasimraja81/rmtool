# Step 1: Use a clean base with all compiler tools
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies needed for compiling the Fortran/C code
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gfortran \
    gcc-offload-nvptx \
    nvptx-tools \
    make \
    libcfitsio-dev \
    libcurl4-openssl-dev \
    libnghttp2-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Fix working directory to guarantee relative paths work
WORKDIR /app/rmtool

# Copy everything from the build context root directory into /app/rmtool
COPY . .

# Run sequenced builds using your exact Makefile variables
RUN set -e; \
    # 0. Create missing directories that were ignored by .dockerignore \
    mkdir -p bin build; \
    \
    # 1. Build configuration: OMP=0 GPU=0
    make clean OMP=0 GPU=0; \
    make -j2 OMP=0 GPU=0; \
    mv bin/rm_synthesis_release_omp0_gpu0 bin/rm_synthesis_OMP0_GPU0; \
    \
    # 2. Build configuration: OMP=1 GPU=0
    make clean OMP=1 GPU=0; \
    make -j2 OMP=1 GPU=0; \
    mv bin/rm_synthesis_release_omp1_gpu0 bin/rm_synthesis_OMP1_GPU0; \
    \
    # 3. Build configuration: OMP=0 GPU=1
    make clean OMP=0 GPU=1; \
    make -j2 OMP=0 GPU=1; \
    mv bin/rm_synthesis_release_omp0_gpu1 bin/rm_synthesis_OMP0_GPU1

# Expose all three compiled targets to the container's system PATH
ENV PATH="/app/rmtool/bin:${PATH}"

CMD ["/bin/bash"]
