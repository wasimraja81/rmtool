# Step 1: Use a clean base with all compiler tools
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

ARG RMTOOL_GIT_TAG=unknown
LABEL org.opencontainers.image.title="rmtool" \
    org.opencontainers.image.version="${RMTOOL_GIT_TAG}" \
    org.opencontainers.image.description="RM synthesis toolchain image built from a tagged source snapshot"

# Install dependencies needed for compiling the Fortran/C code
# and running Python plotting scripts in-container.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gfortran \
    gcc-offload-nvptx \
    nvptx-tools \
    make \
    python3 \
    python3-pip \
    python3-venv \
    python3-matplotlib \
    python3-numpy \
    python3-astropy \
    libcfitsio-dev \
    libcurl4-openssl-dev \
    libnghttp2-dev \
    libstarlink-ast-dev \
    libstarlink-ast-err9 \
    libstarlink-ast-grf3d9 \
    libstarlink-pal-dev \
    libfftw3-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Fix working directory to guarantee relative paths work
WORKDIR /app/rmtool

# Copy everything from the build context root directory into /app/rmtool
COPY . .

# Run sequenced builds for all OMP/GPU combinations.
# The Makefile emits names like rm_synthesis_release_cpu_serial, etc.
RUN set -eux; \
    mkdir -p bin build; \
    make clean OMP=0 GPU=0; \
    make -j2 OMP=0 GPU=0; \
    cp -f bin/rm_synthesis_release_cpu_serial bin/rm_synthesis_OMP0_GPU0; \
    make clean OMP=1 GPU=0; \
    make -j2 OMP=1 GPU=0; \
    cp -f bin/rm_synthesis_release_cpu_omp bin/rm_synthesis_OMP1_GPU0; \
    make clean OMP=0 GPU=1; \
    make -j2 OMP=0 GPU=1; \
    cp -f bin/rm_synthesis_release_gpu_offload bin/rm_synthesis_OMP0_GPU1; \
    make clean OMP=1 GPU=1; \
    make -j2 OMP=1 GPU=1; \
    cp -f bin/rm_synthesis_release_gpu_offload_hostomp bin/rm_synthesis_OMP1_GPU1

# reproject_cubes: independent of the rm_synthesis build graph above (own
# binary, own AST dependency -- see the Makefile's own comment), so it
# isn't touched by any of the `make clean OMP=... GPU=...` calls above
# (those only remove rm_synthesis-specific build artifacts). Built once,
# ends up at bin/reproject_cubes.
RUN make reproject_cubes

# convolve_cubes: common-resolution convolution tool (gaussft_mod +
# commonbeam_mod -- see the Makefile's own comment), likewise independent
# of the rm_synthesis build graph and of reproject_cubes' own AST
# dependency (own binary, own FFTW3 dependency via libfftw3-dev above).
# Built once, ends up at bin/convolve_cubes.
RUN make convolve_cubes

# plot_tile_async_swimlane.py: symlinked into bin/ (not copied) so there's
# one source of truth -- editing scripts/plot_tile_async_swimlane.py in a
# later image layer or a bind-mounted dev checkout is still what actually
# runs. Its own shebang (#!/usr/bin/env python3) already resolves to
# whichever python3 is first on PATH; inside this image that's the
# apt-get python3 installed above (with matplotlib/numpy/astropy already
# on it, not some other interpreter), so it needs no rewriting -- only
# needs to be executable (already is, tracked in git) and reachable from
# PATH like every other tool here.
RUN chmod +x scripts/plot_tile_async_swimlane.py \
    && ln -sf /app/rmtool/scripts/plot_tile_async_swimlane.py \
       bin/plot_tile_async_swimlane.py

# Expose all four compiled rm_synthesis targets plus reproject_cubes and
# plot_tile_async_swimlane.py to the container's system PATH
ENV PATH="/app/rmtool/bin:${PATH}"

CMD ["/bin/bash"]
